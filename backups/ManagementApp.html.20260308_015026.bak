        <span style="color: var(--warning-yellow); margin-right: 10px;">BUILD: 2026-03-07 15:03</span>
        <span id="sync-status">LIVE SYNC</span>
      </div>
    </footer>

    <div id="mission-editor-overlay" class="mission-editor-overlay" aria-hidden="true">
      <div class="mission-editor-modal" role="dialog" aria-modal="true" aria-labelledby="mission-editor-title">
