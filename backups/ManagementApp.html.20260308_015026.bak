          { text: "Create Social Accounts (FB, LinkedIn, IG Booking Portfolio Page)", subtext: "MARKETING & BRAND" },
          { text: "SEO for Projecttitle.co.uk (http://projecttitle.co.uk/)", subtext: "MARKETING & BRAND" },
