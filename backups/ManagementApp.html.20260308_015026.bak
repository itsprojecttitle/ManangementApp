        <div class="intel-actions">
          <button class="confirm-btn" type="button" onclick="closeIntelPopup()">Close</button>
          <button id="intel-delete-btn" class="bb-delete-btn" type="button" onclick="deleteIntelPopup()" style="display:none;">Delete</button>
          <button id="intel-save-btn" class="submit-btn" type="button" onclick="saveIntelPopup()" style="display:none;">Save</button>
        </div>
