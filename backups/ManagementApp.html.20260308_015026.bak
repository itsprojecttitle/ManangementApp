<!-- LIVE_MARKER_221907 -->
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050505" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" href="/icon-192.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />
    <title>S.A.M.U.E.L // OMNI-DASHBOARD</title>
    <style>
      :root {
        --bg-color: #050505;
        --term-green: #00ff41;
        --term-dim: #004411;
        --alert-red: #ff3333;
        --warning-yellow: #ffcc00;
        --panel-bg: rgba(0, 20, 0, 0.6);
        --border-style: 1px solid var(--term-green);
      }

      body {
        background-color: var(--bg-color);
        color: var(--term-green);
        font-family: "Courier New", Courier, monospace;
        margin: 0;
        padding: 20px;
        height: 100vh;
        overflow: hidden;
        display: grid;
        grid-template-columns: 250px 1fr;
        grid-template-rows: 60px 1fr 30px;
        gap: 15px;
      }

      /* HEADER */
      header {
        grid-column: 1 / -1;
        border-bottom: 2px solid var(--term-green);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        text-shadow: 0 0 10px var(--term-green);
      }

      .system-status {
        font-size: 0.8rem;
        color: var(--term-dim);
      }

      .status-active {
        color: var(--term-green);
      }

      /* GLOBAL SEARCH */
      #global-search-container {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--panel-bg);
        border: 1px solid var(--term-dim);
        padding: 5px 10px;
      }
      #global-search {
        background: transparent;
        border: none;
        color: var(--term-green);
        font-family: inherit;
        outline: none;
        width: 200px;
      }

      /* SIDEBAR NAV */
      aside {
        grid-row: 2 / 3;
        border: var(--border-style);
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: var(--panel-bg);
      }

      .nav-btn {
        background: transparent;
        border: 1px solid var(--term-dim);
        color: var(--term-green);
        padding: 15px;
        text-align: left;
        cursor: pointer;
        transition: 0.2s;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
      }

      .nav-btn:hover,
      .nav-btn.active {
        background: var(--term-green);
        color: black;
        box-shadow: 0 0 15px var(--term-green);
      }
      .nav-btn.nav-yellow {
        color: var(--warning-yellow);
        border-color: #8a6b00;
      }
      .nav-btn.nav-yellow:hover,
      .nav-btn.nav-yellow.active {
        background: var(--warning-yellow);
        color: black;
        box-shadow: 0 0 15px var(--warning-yellow);
      }
      .nav-btn.nav-red {
        color: var(--alert-red);
        border-color: #7a1a1a;
      }
      .nav-btn.nav-red:hover,
      .nav-btn.nav-red.active {
        background: var(--alert-red);
        color: black;
        box-shadow: 0 0 15px var(--alert-red);
      }

      /* MAIN CONTENT AREA */
      main {
        grid-row: 2 / 3;
        border: var(--border-style);
        padding: 20px;
        overflow-y: auto;
        position: relative;
        background: radial-gradient(circle at center, #0a1a0a 0%, #000 100%);
      }

      .view-panel {
        display: none;
      }
      .view-panel.active {
        display: block;
        animation: fadeIn 0.3s ease-in;
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      h2 {
        border-bottom: 1px dashed var(--term-green);
        padding-bottom: 10px;
        margin-top: 0;
      }

      /* DATA TABLES */
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
        font-size: 0.9rem;
      }
      th, td {
        border: 1px solid var(--term-dim);
        padding: 8px;
        text-align: left;
      }
      th {
        background-color: var(--term-dim);
        color: var(--term-green);
      }
      tr:hover {
        background-color: rgba(0, 255, 65, 0.1);
      }
      #view-blackbook input,
      #view-blackbook select {
        width: 100%;
        background: rgba(0, 0, 0, 0.45);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        padding: 4px 6px;
        box-sizing: border-box;
      }

      /* OPERATION MODULES GRID */
      .ops-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 15px;
      }
      .op-card {
        border: 1px solid var(--term-green);
        padding: 15px;
        text-align: center;
        cursor: pointer;
        position: relative;
        user-select: none;
      }
      .op-card[draggable="true"] {
        cursor: grab;
      }
      .op-card.drag-over {
        border-style: dashed;
        background: rgba(0, 255, 65, 0.12);
      }
      .op-card:hover {
        background: var(--term-dim);
      }
      .op-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 10px;
      }
      #book-grid.book-split {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }
      .book-section {
        border: 1px solid var(--term-green);
        padding: 10px;
        background: rgba(0, 18, 0, 0.4);
      }
      .book-section-title {
        font-weight: bold;
        margin-bottom: 8px;
      }
      .book-section-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 8px;
      }
      .book-card {
        border: 1px solid var(--term-green);
        padding: 8px;
        cursor: pointer;
        background: rgba(0, 0, 0, 0.45);
      }
      .book-card:hover {
        background: var(--term-dim);
      }
      .book-card .op-icon {
        font-size: 1.1rem;
        margin-bottom: 4px;
        display: inline-block;
      }
      .book-title {
        font-weight: bold;
        font-size: 0.82rem;
        line-height: 1.2;
        margin-bottom: 4px;
      }
      .book-meta {
        font-size: 0.72rem;
        color: var(--warning-yellow);
        margin-bottom: 3px;
      }
      .book-path {
        font-size: 0.72rem;
        color: var(--term-dim);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      @media (max-width: 1100px) {
        #book-grid.book-split {
          grid-template-columns: 1fr;
        }
      }
      .op-delete-btn {
        position: absolute;
        top: 5px;
        right: 5px;
        background: transparent;
        border: none;
        color: var(--alert-red);
        cursor: pointer;
        font-size: 1rem;
        opacity: 0.3;
        transition: 0.2s;
      }
      .op-color-wrap {
        position: absolute;
        top: 7px;
        right: 29px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }
      .op-color-input {
        width: 100%;
        height: 100%;
        padding: 0;
        border: 1px solid var(--term-green);
        border-radius: 50%;
        background: rgba(0, 15, 0, 0.95);
        cursor: pointer;
        opacity: 0.92;
      }
      .op-color-input::-webkit-color-swatch-wrapper {
        padding: 0;
        border-radius: 50%;
      }
      .op-color-input::-webkit-color-swatch {
        border: none;
        border-radius: 50%;
      }
      .op-color-reset-mini {
        position: absolute;
        right: 8px;
        bottom: 8px;
        width: 14px;
        height: 14px;
        border: 1px solid #8a6b00;
        border-radius: 50%;
        background: rgba(255, 204, 0, 0.92);
        color: #000;
        cursor: pointer;
        font-size: 0.55rem;
        line-height: 1;
        padding: 0;
        opacity: 0.75;
      }
      .op-card:hover .op-color-reset-mini {
        opacity: 1;
      }
      .op-card:hover .op-delete-btn {
        opacity: 1;
      }

      /* BACK BUTTON */
      .back-btn {
        background: var(--term-dim);
        border: 1px solid var(--term-green);
        color: var(--term-green);
        padding: 5px 15px;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 15px;
        display: inline-block;
      }
      .back-btn:hover {
        background: var(--term-green);
        color: black;
      }

      .hidden-by-default {
  display: none;
}

      .mission-status-select {
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        font-weight: bold;
        padding: 4px 8px;
        text-transform: uppercase;
      }
      .mission-status-select.status-pending {
        color: var(--warning-yellow);
      }
      .mission-status-select.status-in-progress,
      .mission-status-select.status-complete {
        color: var(--term-green);
      }
      .mission-status-select.status-blocked {
        color: var(--alert-red);
      }
      .quarter-slot {
        margin-top: 10px;
        padding: 8px;
        border: 1px solid var(--term-dim);
        background: linear-gradient(180deg, rgba(0, 30, 0, 0.35), rgba(0, 10, 0, 0.55));
      }
      .quarter-slot.block-tint-1 { background: linear-gradient(180deg, rgba(0, 30, 0, 0.28), rgba(0, 14, 0, 0.5)); }
      .quarter-slot.block-tint-2 { background: linear-gradient(180deg, rgba(0, 36, 0, 0.28), rgba(0, 16, 0, 0.52)); }
      .quarter-slot.block-tint-3 { background: linear-gradient(180deg, rgba(0, 28, 8, 0.3), rgba(0, 12, 6, 0.52)); }
      .quarter-slot.block-tint-4 { background: linear-gradient(180deg, rgba(0, 26, 12, 0.3), rgba(0, 10, 8, 0.52)); }
      .quarter-slot.recovery-slot {
        border-color: #8a6b00;
        background: linear-gradient(180deg, rgba(35, 26, 0, 0.35), rgba(18, 12, 0, 0.6));
      }
      .quarter-slot-time {
        color: #9cffbf;
        font-size: 0.86rem;
        font-weight: 700;
        line-height: 1.35;
        margin-bottom: 6px;
        text-shadow: 0 0 8px rgba(0, 255, 65, 0.25);
      }
      .slot-label {
        color: var(--warning-yellow);
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-top: 6px;
      }
      .matrix-select {
        width: 100%;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background:
          linear-gradient(45deg, transparent 50%, var(--warning-yellow) 50%) calc(100% - 16px) calc(50% - 3px) / 7px 7px no-repeat,
          linear-gradient(135deg, var(--warning-yellow) 50%, transparent 50%) calc(100% - 11px) calc(50% - 3px) / 7px 7px no-repeat,
          linear-gradient(180deg, rgba(0, 28, 0, 0.88), rgba(0, 14, 0, 0.95));
        color: var(--term-green);
        border: 1px solid #1ca34b;
        border-radius: 4px;
        font-family: inherit;
        font-weight: bold;
        padding: 8px 30px 8px 10px;
        margin-top: 6px;
        box-shadow: inset 0 0 10px rgba(0, 255, 65, 0.12), 0 0 0 1px rgba(0, 255, 65, 0.1);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.05s ease;
      }
      .matrix-select:hover {
        border-color: var(--warning-yellow);
        box-shadow: inset 0 0 12px rgba(0, 255, 65, 0.14), 0 0 10px rgba(255, 204, 0, 0.18);
      }
      .matrix-select:focus {
        outline: none;
        border-color: var(--warning-yellow);
        box-shadow: 0 0 14px rgba(255, 204, 0, 0.4), inset 0 0 10px rgba(0, 255, 65, 0.12);
        transform: translateY(-1px);
      }
      .matrix-select option {
        background: #061206;
        color: var(--term-green);
      }
      .matrix-select.recovery-select {
        border-color: #d4a900;
        color: var(--warning-yellow);
        background:
          linear-gradient(45deg, transparent 50%, var(--warning-yellow) 50%) calc(100% - 16px) calc(50% - 3px) / 7px 7px no-repeat,
          linear-gradient(135deg, var(--warning-yellow) 50%, transparent 50%) calc(100% - 11px) calc(50% - 3px) / 7px 7px no-repeat,
          linear-gradient(180deg, rgba(35, 26, 0, 0.82), rgba(18, 12, 0, 0.92));
      }
      .matrix-select.recovery-select option {
        background: #1a1300;
        color: var(--warning-yellow);
      }
      .focus-header {
        border: 1px solid var(--warning-yellow);
        background: linear-gradient(180deg, rgba(28, 22, 0, 0.35), rgba(10, 8, 0, 0.6));
        padding: 12px;
        text-align: center;
        margin-bottom: 10px;
      }
      .focus-day {
        color: var(--term-dim);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .focus-quarter {
        color: var(--warning-yellow);
        font-size: 1.35rem;
        font-weight: bold;
        margin: 4px 0;
        text-transform: uppercase;
      }
      .focus-phase {
        display: inline-block;
        border: 1px solid var(--warning-yellow);
        background: rgba(255, 204, 0, 0.08);
        color: var(--warning-yellow);
        font-weight: bold;
        padding: 5px 10px;
        margin-top: 6px;
        text-transform: uppercase;
      }
      .focus-cadence {
        color: var(--term-green);
        margin-top: 8px;
        font-size: 0.9rem;
      }

      /* THEMED CONFIRM MODAL */
      .confirm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }
      .confirm-overlay.active {
        display: flex;
      }
      .confirm-modal {
        width: min(480px, 92vw);
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #061306 0%, #020202 100%);
        box-shadow: 0 0 30px rgba(0, 255, 65, 0.25);
        padding: 18px;
      }
      .confirm-title {
        margin: 0 0 12px 0;
        color: var(--warning-yellow);
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .confirm-message {
        margin: 0 0 16px 0;
        color: var(--term-green);
      }
      .confirm-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
      }
      .confirm-btn {
        background: transparent;
        border: 1px solid var(--term-green);
        color: var(--term-green);
        padding: 8px 12px;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
      }
      .confirm-btn:hover {
        background: var(--term-green);
        color: #000;
      }
      .confirm-btn.danger {
        border-color: var(--alert-red);
        color: var(--alert-red);
      }
      .confirm-btn.danger:hover {
        background: var(--alert-red);
        color: #000;
      }
      .mission-editor-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.76);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10001;
      }
      .mission-editor-overlay.active {
        display: flex;
      }
      .mission-editor-modal {
        width: min(980px, 96vw);
        max-height: 90vh;
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #071707 0%, #020202 100%);
        box-shadow: 0 0 28px rgba(0, 255, 65, 0.25);
        display: grid;
        grid-template-rows: auto 1fr auto;
      }
      .mission-editor-head {
        border-bottom: 1px solid var(--term-dim);
        padding: 10px 12px;
      }
      .mission-editor-title {
        margin: 0;
        color: var(--warning-yellow);
      }
      .mission-editor-path {
        color: var(--term-dim);
        font-size: 0.82rem;
        margin-top: 4px;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.25;
      }
      .mission-editor-body {
        padding: 12px;
        overflow: auto;
        min-height: 0;
      }
      .mission-editor-textarea {
        width: 100%;
        min-height: 0;
        height: 100%;
        background: rgba(0, 0, 0, 0.74);
        color: var(--term-green);
        border: 1px solid var(--term-green);
        font-family: inherit;
        font-size: 0.92rem;
        line-height: 1.45;
        padding: 12px;
        box-sizing: border-box;
        resize: vertical;
      }
      .mission-editor-textarea:focus {
        outline: none;
        border-color: var(--warning-yellow);
        box-shadow: 0 0 14px rgba(255, 204, 0, 0.24);
      }
      .mission-editor-actions {
        border-top: 1px solid var(--term-dim);
        padding: 10px 12px;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
      }
      .intel-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.76);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10002;
      }
      .intel-overlay.active {
        display: flex;
      }
      .intel-modal {
        width: min(900px, 96vw);
        max-height: 90vh;
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #071707 0%, #020202 100%);
        box-shadow: 0 0 28px rgba(0, 255, 65, 0.25);
        display: grid;
        grid-template-rows: auto 1fr auto;
      }
      .intel-head {
        border-bottom: 1px solid var(--term-dim);
        padding: 10px 12px;
      }
      .intel-title {
        margin: 0;
        color: var(--warning-yellow);
      }
      .intel-subtitle {
        margin-top: 4px;
        color: var(--term-dim);
        font-size: 0.82rem;
      }
      .intel-body {
        padding: 12px;
        overflow: auto;
      }
      .intel-actions {
        border-top: 1px solid var(--term-dim);
        padding: 10px 12px;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
      }
      .intel-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .intel-grid .form-group {
        margin-bottom: 0;
      }
      .intel-grid .full {
        grid-column: 1 / -1;
      }
      .intel-card {
        border: 1px solid var(--term-green);
        background: rgba(0, 255, 65, 0.05);
        padding: 10px;
      }
      .hvi-popup-card p {
        margin: 4px 0;
        font-size: 0.88rem;
        line-height: 1.35;
      }
      .hvi-popup-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .hvi-popup-nav {
        margin-top: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
      }
      .hvi-inline-actions {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
      }
      .hvi-add-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 6px;
        margin-top: 6px;
      }
      .hvi-add-row.double {
        grid-template-columns: 1fr 1fr auto;
      }
      .hvi-list-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 6px;
        align-items: center;
      }
      .hvi-list-row .x-btn {
        min-width: 32px;
      }
      .hvi-field-label {
        display: block;
        color: var(--warning-yellow);
        font-weight: 700;
        font-size: 0.82rem;
        margin-bottom: 2px;
      }
      .hvi-field-value {
        display: block;
        color: var(--term-green);
        font-size: 0.9rem;
        word-break: break-word;
      }
      .hvi-stat-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 6px;
        align-items: center;
        border: 1px solid var(--term-dim);
        padding: 6px;
        margin-bottom: 6px;
        background: rgba(0, 255, 65, 0.03);
        cursor: move;
      }
      .hvi-stat-row.drag-over {
        border-color: var(--warning-yellow);
        background: rgba(255, 204, 0, 0.07);
      }
      .doc-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.82);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10005;
      }
      .doc-overlay.active {
        display: flex;
      }
      .doc-modal {
        width: min(1120px, 96vw);
        height: min(86vh, 920px);
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #071707 0%, #020202 100%);
        box-shadow: 0 0 30px rgba(0, 255, 65, 0.25);
        display: grid;
        grid-template-rows: auto 1fr;
      }
      .doc-head {
        border-bottom: 1px solid var(--term-dim);
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }
      .doc-title {
        margin: 0;
        color: var(--warning-yellow);
      }
      .doc-sub {
        color: var(--term-dim);
        font-size: 0.82rem;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.25;
      }
      .doc-body {
        padding: 12px;
        overflow: auto;
      }
      .ctx-key {
        font-weight: 700;
        color: #ffd84a;
      }
      .ctx-key-primary {
        color: #ffd84a;
      }
      .ctx-key-status {
        color: #00d4ff;
      }
      .ctx-key-risk {
        color: #ff5f5f;
      }
      .ctx-key-result {
        color: #7dff8a;
      }

      /* HVI CARDS */
      .hvi-card {
        border-left: 4px solid var(--warning-yellow);
        background: rgba(255, 204, 0, 0.05);
        margin-bottom: 10px;
        padding: 10px;
        cursor: pointer;
      }

      /* PROBE MANUAL STYLES */
      .manual-view {
        line-height: 1.6;
        max-width: 800px;
      }
      .manual-view h1, .manual-view h2, .manual-view h3 {
        color: var(--warning-yellow);
        border-bottom: 1px solid var(--term-dim);
        margin-top: 25px;
      }
      .mission-brief-view h1, .mission-brief-view h2, .mission-brief-view h3 {
        color: #ffd84a;
        text-shadow: 0 0 10px rgba(255, 216, 74, 0.28);
      }
      .manual-view ul {
        padding-left: 20px;
      }
      .manual-view code {
        background: var(--term-dim);
        padding: 2px 5px;
      }
      /* FOOTER */
      footer {
        grid-column: 1 / -1;
        border-top: var(--border-style);
        display: flex;
        align-items: center;
        padding: 0 20px;
        font-size: 0.8rem;
        justify-content: space-between;
      }

      /* SUBMISSION FORMS */
      .submission-area {
        border: 1px dashed var(--term-green);
        background: rgba(0, 255, 65, 0.05);
        padding: 20px;
        margin-bottom: 20px;
      }
      .form-group {
        margin-bottom: 15px;
      }
      .form-group label {
        display: block;
        margin-bottom: 5px;
        color: var(--term-green);
        opacity: 0.8;
      }
      .form-group input, .form-group select, .form-group textarea {
        width: 100%;
        padding: 8px;
        background-color: var(--bg-color);
        border: 1px solid var(--term-dim);
        color: var(--term-green);
        font-family: inherit;
        box-sizing: border-box;
      }
      .form-group textarea {
        min-height: 96px;
        resize: vertical;
        line-height: 1.4;
      }
      .submit-btn {
        background-color: var(--term-dim);
        color: var(--term-green);
        border: 1px solid var(--term-green);
        padding: 10px 20px;
        cursor: pointer;
        font-weight: bold;
        text-transform: uppercase;
      }
      .submit-btn:hover {
        background-color: var(--term-green);
        color: var(--bg-color);
      }
      .bb-actions {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
      }
      .bb-save-btn {
        padding: 4px 10px;
      }
      .bb-delete-btn {
        background: rgba(255, 204, 0, 0.08);
        color: var(--warning-yellow);
        border: 1px solid #8a6b00;
        padding: 4px 9px;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
      }
      .bb-delete-btn:hover {
        background: var(--warning-yellow);
        color: #000;
      }
      .x-btn {
        background: rgba(255, 204, 0, 0.08);
        color: var(--warning-yellow);
        border: 1px solid #8a6b00;
        padding: 4px 9px;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
      }
      .x-btn:hover {
        background: var(--warning-yellow);
        color: #000;
      }
      .mission-actions-inline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        flex-wrap: nowrap;
      }
      .mission-actions-inline .x-btn {
        min-width: 32px;
      }
      /* Universal popup + dropdown theme normalization */
      select,
      .form-group select,
      .brief-toolbar select,
      .mission-status-select,
      #intel-overlay select,
      #confirm-overlay select,
      #doc-overlay select,
      #mission-editor-overlay select {
        -webkit-appearance: none;
        appearance: none;
        background: linear-gradient(180deg, rgba(0, 22, 0, 0.8), rgba(0, 8, 0, 0.92));
        border: 1px solid var(--term-green);
        color: var(--term-green);
        font-family: inherit;
      }
      option {
        background: #031005;
        color: var(--term-green);
      }
      .search-input,
      .form-group input,
      .form-group textarea,
      .mission-editor-textarea {
        background: rgba(0, 0, 0, 0.78);
        border: 1px solid var(--term-dim);
        color: var(--term-green);
      }
      .confirm-modal,
      .mission-editor-modal,
      .intel-modal,
      .doc-modal {
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #071707 0%, #020202 100%);
        box-shadow: 0 0 28px rgba(0, 255, 65, 0.25);
      }
      .confirm-btn {
        background: rgba(0, 255, 65, 0.08);
        color: var(--term-green);
        border: 1px solid var(--term-green);
      }
      .confirm-btn:hover {
        background: var(--term-green);
        color: #000;
      }
      .confirm-btn.danger {
        border-color: #8a6b00;
        color: var(--warning-yellow);
        background: rgba(255, 204, 0, 0.08);
      }
      .confirm-btn.danger:hover {
        background: var(--warning-yellow);
        color: #000;
      }
      .search-toolbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        margin: 10px 0 12px 0;
      }
      .search-input {
        width: 100%;
        padding: 8px 10px;
        background: rgba(0, 0, 0, 0.7);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        box-sizing: border-box;
      }
      .checklist-toolbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        margin-bottom: 12px;
      }
      .checklist-add-fields {
        display: grid;
        gap: 8px;
      }
      .checklist-panel {
        border: 1px solid var(--term-green);
        background: linear-gradient(180deg, rgba(0, 255, 65, 0.06), rgba(0, 0, 0, 0.4));
        box-shadow: inset 0 0 24px rgba(0, 255, 65, 0.08);
        padding: 12px;
      }
      .checklist-input {
        width: 100%;
        padding: 10px;
        background: rgba(0, 0, 0, 0.7);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        box-sizing: border-box;
      }
      .checklist-input:focus {
        outline: none;
        border-color: var(--warning-yellow);
        box-shadow: 0 0 12px rgba(255, 204, 0, 0.2);
      }
      .checklist-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border: 1px solid var(--term-green);
      }
      .checklist-item {
        display: grid;
        grid-template-columns: auto auto 1fr auto;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-bottom: 1px solid var(--term-dim);
        background: linear-gradient(90deg, rgba(0, 255, 65, 0.08), rgba(0, 0, 0, 0.2));
        cursor: grab;
      }
      .checklist-item:hover {
        background: linear-gradient(90deg, rgba(0, 255, 65, 0.14), rgba(0, 0, 0, 0.26));
      }
      .checklist-item:last-child {
        border-bottom: none;
      }
      .checklist-item.drag-over {
        background: rgba(255, 204, 0, 0.12);
      }
      .checklist-item.done .checklist-text {
        opacity: 0.55;
        text-decoration: line-through;
      }
      .checklist-item.done .checklist-subtext {
        opacity: 0.45;
      }
      .checklist-handle {
        color: var(--term-dim);
        font-weight: bold;
      }
      .checklist-check {
        width: 16px;
        height: 16px;
        accent-color: #66ff66;
      }
      .checklist-text {
        word-break: break-word;
      }
      .checklist-copy {
        display: grid;
        gap: 4px;
      }
      .checklist-subtext {
        color: var(--warning-yellow);
        font-size: 0.82rem;
        line-height: 1.3;
        word-break: break-word;
      }
      .checklist-empty {
        border: 1px dashed var(--term-green);
        padding: 14px;
        color: var(--term-dim);
        background: rgba(0, 255, 65, 0.04);
      }
      .brief-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 14px;
      }
      .brief-main,
      .brief-side {
        border: 1px solid var(--term-green);
        background: linear-gradient(180deg, rgba(0, 255, 65, 0.05), rgba(0, 0, 0, 0.45));
        box-shadow: inset 0 0 20px rgba(0, 255, 65, 0.08);
        padding: 10px;
      }
      .brief-toolbar {
        display: grid;
        grid-template-columns: 1fr 1fr auto auto auto;
        gap: 8px;
        margin-bottom: 10px;
      }
      .brief-toolbar select,
      .brief-toolbar input {
        width: 100%;
        padding: 8px;
        background: rgba(0, 0, 0, 0.7);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        box-sizing: border-box;
      }
      .brief-toolbar select:focus,
      .brief-toolbar input:focus {
        outline: none;
        border-color: var(--warning-yellow);
        box-shadow: 0 0 12px rgba(255, 204, 0, 0.2);
      }
      .brief-editor {
        width: 100%;
        min-height: 360px;
        background: rgba(0, 0, 0, 0.72);
        color: var(--term-green);
        border: 1px solid var(--term-green);
        font-family: inherit;
        padding: 10px;
        box-sizing: border-box;
        resize: vertical;
        box-shadow: inset 0 0 16px rgba(0, 255, 65, 0.08);
      }
      .brief-editor:focus {
        outline: none;
        border-color: var(--warning-yellow);
        box-shadow: 0 0 12px rgba(255, 204, 0, 0.25), inset 0 0 16px rgba(0, 255, 65, 0.1);
      }
      .brief-side h4 {
        margin: 0 0 8px 0;
        color: var(--warning-yellow);
        border-bottom: 1px dashed #8a6b00;
        padding-bottom: 6px;
      }
      .brief-var-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
        margin-bottom: 6px;
      }
      #brief-vars input {
        width: 100%;
        padding: 8px;
        background: rgba(0, 0, 0, 0.72);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        box-sizing: border-box;
      }
      #brief-vars input:focus {
        outline: none;
        border-color: var(--warning-yellow);
      }
      .brief-history-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border: 1px solid var(--term-green);
        background: rgba(0, 0, 0, 0.5);
        max-height: 280px;
        overflow: auto;
      }
      .brief-history-list li {
        border-bottom: 1px solid var(--term-dim);
      }
      .brief-history-list li:last-child {
        border-bottom: none;
      }
      .brief-history-list button {
        width: 100%;
        text-align: left;
        background: transparent;
        border: none;
        color: var(--term-green);
        padding: 8px;
        font-family: inherit;
        cursor: pointer;
      }
      .brief-history-list button:hover {
        background: rgba(0, 255, 65, 0.08);
      }
      .brief-main-actions {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .lock-overlay {
        position: fixed;
        inset: 0;
        z-index: 12000;
        background: rgba(0, 0, 0, 0.94);
        display: none;
        align-items: center;
        justify-content: center;
      }
      .lock-overlay.active {
        display: flex;
      }
      .lock-modal {
        width: min(620px, 94vw);
        border: 1px solid var(--term-green);
        background: radial-gradient(circle at center, #061306 0%, #020202 100%);
        box-shadow: 0 0 30px rgba(0, 255, 65, 0.24);
        padding: 18px;
      }
      .lock-title {
        margin: 0 0 8px 0;
        color: var(--warning-yellow);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .lock-sub {
        color: var(--term-dim);
        margin: 0 0 12px 0;
        font-size: 0.9rem;
      }
      .lock-row {
        margin-bottom: 10px;
      }
      .lock-input {
        width: 100%;
        background: rgba(0, 0, 0, 0.68);
        color: var(--term-green);
        border: 1px solid var(--term-dim);
        font-family: inherit;
        padding: 9px 10px;
        box-sizing: border-box;
      }
      .lock-input:focus {
        outline: none;
        border-color: var(--warning-yellow);
      }
      .lock-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
      }
      .lock-meta {
        margin-top: 10px;
        color: var(--term-dim);
        font-size: 0.82rem;
      }
      .lock-recovery {
        margin-top: 12px;
        border: 1px solid #8a6b00;
        background: rgba(255, 204, 0, 0.08);
        padding: 10px;
        display: none;
      }
      .lock-recovery.active {
        display: block;
      }
      .lock-recovery-code {
        margin-top: 8px;
        font-weight: bold;
        color: var(--warning-yellow);
        word-break: break-all;
      }
      /* HIDDEN DELETE BUTTONS */
      .hidden-by-default {
        display: none;
      }.hidden-by-default {
  display: none;
}
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <header>
      <h1>// MANAGEMENT_APP_V1.3</h1>
      <div class="system-status">
        CORE: <span class="status-active">ONLINE</span> | CONNECTION:
        <span class="status-active">SECURE</span> | USER: SLIDER
      </div>
    </header>

    <!-- NAVIGATION SIDEBAR -->
    <aside>
      <button class="nav-btn active" onclick="switchView('dashboard')">[00] DASHBOARD</button>
      <button class="nav-btn" id="nav-ops" onclick="switchView('operations')">[01] OPERATIONS</button>
      <button class="nav-btn" onclick="switchView('blackbook')">[02] BLACK BOOK</button>
      <button class="nav-btn" onclick="switchView('hvi-intel')">[03] HVI TARGETS</button>
      <button class="nav-btn nav-yellow" onclick="switchView('brief-studio')">[04] BRIEF STUDIO</button>
      <button class="nav-btn nav-yellow" onclick="switchView('probe-skill')">[05] PROBE SKILL</button>
      <button class="nav-btn nav-yellow" onclick="switchView('probe-manual')">[06] PROBE MANUEL</button>
      <button class="nav-btn nav-yellow" onclick="switchView('mission-briefing')">[07] MISSION BRIEFING</button>
      <button class="nav-btn nav-red" onclick="switchView('checklist')">[08] CHECKLIST</button>
      <button class="nav-btn nav-red" onclick="switchView('blueprints')">[09] ORACLE</button>
      <button class="nav-btn nav-red" onclick="switchView('books')">[10] BOOKS</button>
      <button class="nav-btn nav-red" onclick="switchView('swissknife')">[11] SWISSKNIFE</button>
    </aside>

    <!-- MAIN DISPLAY -->
    <main id="main-screen">
      <!-- DASHBOARD VIEW -->
      <div id="view-dashboard" class="view-panel active">
        <h2>// SYSTEM OVERVIEW</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px">
          <div class="op-card" onclick="switchView('operations')">
            <span class="op-icon">📁</span>
            <h3>OPERATIONS</h3>
            <h1 style="margin: 0" id="op-count-dash">0</h1>
          </div>
          <div class="op-card" onclick="switchView('operations')">
            <span class="op-icon">⚡</span>
            <h3>MISSIONS</h3>
            <h1 style="margin: 0" id="mission-count-dash">0</h1>
          </div>
          <div class="op-card" onclick="switchView('hvi-intel')">
            <span class="op-icon">🎯</span>
            <h3>HVI Intel</h3>
            <h1 style="margin: 0" id="hvi-count">0</h1>
          </div>
        </div>
        <br />
        <h3>// TOP MISSIONS OF THE DAY</h3>
        <div id="operation-focus-list">
          <div class="hvi-card" style="border-color: var(--term-green)">
            No mission activity yet.
          </div>
        </div>
      </div>

      <!-- MISSION LOG VIEW -->
      <div id="view-mission-log" class="view-panel">
        <button class="back-btn" onclick="switchView('operations')">< BACK TO OPERATIONS</button>
        <h2 id="mission-header">// MASTER MISSION INDEX</h2>
        <p>Source: <code id="mission-source-code">OperationDir/Operations/[OP]/Missions/[BRIEF]</code></p>
        <div class="search-toolbar">
          <input class="search-input" id="mission-search-input" type="text" placeholder="Search missions or operation..." oninput="setMissionSearch()" onkeydown="if(event.key==='Enter') setMissionSearch()" />
          <button class="submit-btn" type="button" onclick="setMissionSearch()">SEARCH</button>
        </div>

        <div id="mission-submission-area" class="submission-area">
          <h3>+ LOG NEW MISSION</h3>
          <div class="form-group">
            <label for="new-mission-name">Mission Name:</label>
            <input type="text" id="new-mission-name" placeholder="e.g., Acquire Target X Data" />
          </div>
          <div class="form-group">
            <label for="new-mission-op">Operation:</label>
            <input type="text" id="new-mission-op" value="ProjectTitle" />
          </div>
          <div class="form-group">
            <label for="new-mission-status">Status:</label>
            <select id="new-mission-status">
              <option value="PENDING">PENDING</option>
              <option value="IN_PROGRESS">IN_PROGRESS</option>
              <option value="COMPLETE">COMPLETE</option>
              <option value="BLOCKED">BLOCKED</option>
            </select>
          </div>
          <button class="submit-btn" onclick="submitNewMission()">LOG MISSION</button>
          <p id="submission-message" style="margin-top: 10px"></p>
        </div>

        <table id="mission-table">
          <thead>
            <tr>
              <th>DATE</th>
              <th>OPERATION</th>
              <th>MISSION</th>
              <th>STATUS</th>
              <th style="width: 120px;">ACTIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="5">Loading missions...</td></tr>
          </tbody>
        </table>
      </div>

      <!-- OPERATIONS VIEW -->
      <div id="view-operations" class="view-panel">
        <h2>// ACTIVE THEATERS</h2>
        
        <div id="operation-submission-area" class="submission-area">
          <h3>+ CREATE NEW OPERATION</h3>
          <div class="form-group">
            <label for="new-op-name">Operation Name:</label>
            <input type="text" id="new-op-name" placeholder="e.g., TargetRecon" />
          </div>
          <button class="submit-btn" onclick="submitNewOperation()">INITIALIZE OPERATION</button>
          <p id="op-submission-message" style="margin-top: 10px"></p>
        </div>

        <p>Source: <code>OperationDir/Operations/</code></p>
        <div class="search-toolbar">
          <input class="search-input" id="operation-search-input" type="text" placeholder="Search operations..." oninput="setOperationSearch()" onkeydown="if(event.key==='Enter') setOperationSearch()" />
          <button class="submit-btn" type="button" onclick="setOperationSearch()">SEARCH</button>
        </div>
        <div class="ops-grid">
          <div class="op-card" style="position: relative;">
            <button class="op-delete-btn" onclick="deleteOperation('${op}', event)" title="Delete Operation">X</button>
            <span class="op-icon">📁</span>
            ${op.toUpperCase()}
          </div>
        </div>
      </div>

      <!-- BLACK BOOK VIEW -->
      <div id="view-blackbook" class="view-panel">
        <h2>// BLACK BOOK LAB RESULTS</h2>
        <p>Source: <code>OperationDir/BLACK_BOOK.md</code></p>
        <div class="search-toolbar">
          <input class="search-input" id="blackbook-search-input" type="text" placeholder="Search black book..." oninput="setBlackbookSearch()" onkeydown="if(event.key==='Enter') setBlackbookSearch()" />
          <button class="submit-btn" type="button" onclick="setBlackbookSearch()">SEARCH</button>
        </div>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>DATE</th>
              <th>TIME</th>
              <th>OPERATION</th>
              <th>MISSION</th>
              <th>STATUS</th>
              <th>DESCRIPTION</th>
              <th>HYPOTHESIS</th>
              <th>PLATFORM</th>
              <th>RESULT</th>
              <th>NOTES</th>
              <th style="width: 70px;">ACTIONS</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="12">Loading probes...</td></tr>
          </tbody>
        </table>
      </div>

      <div id="view-blueprints" class="view-panel">
        <h2>// ORACLE ARCHIVE</h2>
        <p>Source: <code>BLUEPRINT_*.md</code> | Domains: Compute Sovereignty, Transport Layer, Intelligence & VISINT, Stealth & OSINT, Private Communication.</p>
        <div class="search-toolbar">
          <input class="search-input" id="blueprint-search-input" type="text" placeholder="Search oracle docs..." oninput="setBlueprintSearch()" onkeydown="if(event.key==='Enter') setBlueprintSearch()" />
          <button class="submit-btn" type="button" onclick="setBlueprintSearch()">SEARCH</button>
        </div>
        <h3>// BLUEPRINTS</h3>
        <div id="blueprint-grid" class="ops-grid"></div>
      </div>

      <div id="view-books" class="view-panel">
        <h2>// BOOKS</h2>
        <p>Source: <code>OperationDir/Manuel/</code> (PDF + Markdown + Text)</p>
        <div class="search-toolbar">
          <input class="search-input" id="book-search-input" type="text" placeholder="Search books/manuals..." oninput="setBookSearch()" onkeydown="if(event.key==='Enter') setBookSearch()" />
          <button class="submit-btn" type="button" onclick="setBookSearch()">SEARCH</button>
        </div>
        <div id="book-grid" class="ops-grid"></div>
      </div>

      <div id="view-swissknife" class="view-panel">
        <h2>// SWISSKNIFE DOWNLOAD SESSIONS</h2>
        <p>VM-backed downloads. Credentials stay remote on VM via <code>IG_USER</code>/<code>IG_PASS</code> env vars.</p>
        <div class="submission-area">
          <div class="form-group">
            <label for="swissknife-session-label">Session Label</label>
            <input class="search-input" id="swissknife-session-label" type="text" placeholder="daily / campaign / op-name" />
          </div>
          <button class="submit-btn" type="button" onclick="createSwissknifeSession()">CREATE SESSION</button>
        </div>
        <div class="submission-area">
          <div class="form-group">
            <label for="swissknife-session-select">Session</label>
            <select id="swissknife-session-select"></select>
          </div>
          <div class="form-group">
            <label for="swissknife-url">Instagram URL</label>
            <input class="search-input" id="swissknife-url" type="text" placeholder="https://www.instagram.com/p/SHORTCODE/" />
          </div>
          <div class="form-group">
            <label><input id="swissknife-login" type="checkbox" /> Use VM IG login (--login)</label>
          </div>
          <button class="submit-btn" type="button" onclick="runSwissknifeDownload()">DOWNLOAD TO SESSION</button>
        </div>
        <h3>// SESSION HISTORY</h3>
        <div id="swissknife-session-list" class="manual-view">No sessions yet.</div>
      </div>

      <!-- HVI VIEW -->
      <div id="view-hvi-intel" class="view-panel">
        <h2>// HIGH VALUE INDIVIDUALS (Summary)</h2>
        <p>Source: <code>OperationDir/HVI_INDEX.md</code></p>
        <div class="submission-area" style="margin-top:10px;">
          <h3>+ ADD HVI TARGET</h3>
          <div class="form-group">
            <label for="new-hvi-handle">Handle</label>
            <input class="search-input" id="new-hvi-handle" type="text" placeholder="@target_handle" />
          </div>
          <div class="form-group">
            <label for="new-hvi-status">Status</label>
            <input class="search-input" id="new-hvi-status" type="text" placeholder="ACTIVE / WARM / COLD" />
          </div>
          <div class="form-group">
            <label for="new-hvi-number">Number</label>
            <input class="search-input" id="new-hvi-number" type="text" placeholder="+44 ..." />
          </div>
          <button class="submit-btn" type="button" onclick="submitNewHvi()">ADD HVI</button>
        </div>
        <div class="search-toolbar">
          <input class="search-input" id="hvi-search-input" type="text" placeholder="Search HVI..." oninput="setHviSearch()" onkeydown="if(event.key==='Enter') setHviSearch()" />
          <button class="submit-btn" type="button" onclick="setHviSearch()">SEARCH</button>
        </div>
        <div id="hvi-container">
          <div class="hvi-card"><p>Loading HVI profiles...</p></div>
        </div>
      </div>

      <div id="view-brief-studio" class="view-panel">
        <h2>// BRIEF STUDIO</h2>
        <p>Paste full mission brief text, auto-extract variables, save phase versions, and load previous versions.</p>
        <div class="brief-toolbar">
          <select id="brief-operation-filter" onchange="onBriefOperationFilterChange()"></select>
          <select id="brief-mission-select" onchange="onBriefMissionChange()"></select>
          <input id="brief-phase" type="number" min="1" value="1" title="Phase" />
          <button class="submit-btn" type="button" onclick="loadBriefForSelectedMission()">LOAD</button>
          <button class="submit-btn" type="button" onclick="saveBriefPhase()">SAVE PHASE</button>
        </div>
        <div class="brief-grid">
          <div class="brief-main">
            <textarea id="brief-content" class="brief-editor" placeholder="Paste mission brief here..."></textarea>
            <div class="brief-main-actions">
              <button class="submit-btn" type="button" onclick="parseBriefVariablesFromEditor()">AUTO PARSE VARIABLES</button>
              <button class="submit-btn" type="button" onclick="createNextBriefPhase()">NEXT PHASE (CLONE + COPY)</button>
            </div>
          </div>
          <div class="brief-side">
            <h4>// EXTRACTED VARIABLES</h4>
            <div id="brief-vars"></div>
            <h4 style="margin-top:14px;">// PHASE HISTORY</h4>
            <ul id="brief-history" class="brief-history-list"></ul>
          </div>
        </div>
      </div>

      <!-- PROBE SKILL VIEW -->
      <div id="view-probe-skill" class="view-panel">
        <h2>// PROBE SKILL</h2>
        <p>Source: <code>ProbeSkill.md</code></p>
        <button class="submit-btn" type="button" onclick="copyProbeSkill()" style="margin-bottom: 10px;">COPY</button>
        <div class="manual-view">
          <div id="probe-skill-content">Loading Probe Skill...</div>
        </div>
      </div>

      <!-- PROBE MANUEL VIEW -->
      <div id="view-probe-manual" class="view-panel">
        <h2>// OFFICIAL PROBE MANUEL</h2>
        <p>Source: <code>OfficialProbeManuel.md</code></p>
        <div class="manual-view">
          <div id="probe-manual-content">Loading Probe Manuel...</div>
        </div>
      </div>

      <div id="view-mission-briefing" class="view-panel">
        <h2>// MISSION BRIEFING</h2>
        <p>Source: <code>MissionBriefing.md</code></p>
        <button class="submit-btn" type="button" onclick="copyMissionBriefing()" style="margin-bottom: 10px;">COPY</button>
        <button class="submit-btn" type="button" onclick="openDocEditor('MissionBriefing.md','// MISSION BRIEFING EDITOR','mission-briefing-content')" style="margin-bottom: 10px; margin-left: 8px;">EDIT</button>
        <div class="manual-view mission-brief-view">
          <div id="mission-briefing-content">Loading Mission Briefing...</div>
        </div>
      </div>


      <div id="view-checklist" class="view-panel">
        <h2>// CHECKLIST</h2>
        <p>Track priority actions for this operation day. Add items, mark done, and drag to reorder by execution priority.</p>
        <div class="checklist-panel">
          <div class="checklist-toolbar">
            <div class="checklist-add-fields">
              <input class="checklist-input" type="text" id="checklist-new-item" placeholder="Add checklist item..." onkeydown="onChecklistInputKey(event)" />
              <input class="checklist-input" type="text" id="checklist-new-sub" placeholder="Add sub description (optional)..." onkeydown="onChecklistInputKey(event)" />
            </div>
            <button class="submit-btn" type="button" onclick="addChecklistItem()">ADD</button>
          </div>
          <div id="checklist-empty" class="checklist-empty">No checklist items yet.</div>
          <ul id="checklist-list" class="checklist-list" style="display:none;"></ul>
        </div>
      </div>

      </div>
    </main>

    <!-- FOOTER -->
